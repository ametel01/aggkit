# AggKit Sandbox Environment Variables Template
# Copy this file to .env and modify values as needed

# =============================================================================
# SANDBOX CONFIGURATION
# =============================================================================

# Enable sandbox mode (required for this image)
AGGKIT_SANDBOX_ENABLED=true

# Sandbox behavior settings
AGGKIT_SANDBOX_AUTO_SETTLE=true
AGGKIT_SANDBOX_SETTLEMENT_DELAY=5s
AGGKIT_SANDBOX_MOCK_FINALIZATION=true
AGGKIT_SANDBOX_INSTANT_CLAIMS=true

# =============================================================================
# NETWORK CONFIGURATION
# =============================================================================

# Network identifiers
AGGKIT_NETWORK_ID=1338
AGGKIT_L1_CHAIN_ID=31337
AGGKIT_L2_CHAIN_ID=31338

# Node URLs (adjust if using external nodes)
AGGKIT_L1_URL=http://anvil-l1:8545
AGGKIT_L2_URL=http://anvil-l2:8545

# =============================================================================
# SERVICE CONFIGURATION
# =============================================================================

# API service settings
AGGKIT_REST_HOST=0.0.0.0
AGGKIT_REST_PORT=5577
AGGKIT_RPC_HOST=0.0.0.0
AGGKIT_RPC_PORT=8555
AGGKIT_TELEMETRY_PORT=8080

# Components to run
AGGKIT_COMPONENTS=bridge,aggoracle

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# Database settings (SQLite for sandbox)
AGGKIT_DATABASE_DRIVER=sqlite3
AGGKIT_DATABASE_NAME=/app/data/aggkit_sandbox.db

# =============================================================================
# CONTRACT ADDRESSES
# =============================================================================

# Bridge contract address (update after deployment)
AGGKIT_POLYGON_BRIDGE_ADDRESS=0x2a3DD3EB832aF982ec71669E178424b10Dca2EDe

# EVM sender address (Anvil default account)
AGGKIT_EVM_SENDER=0xf39Fd6e51aad88F6F4ce6aB8827279cffFb92266

# =============================================================================
# DEVELOPMENT SETTINGS
# =============================================================================

# Logging level (debug, info, warn, error)
AGGKIT_LOG_LEVEL=debug

# Wait for dependencies on startup
AGGKIT_WAIT_FOR_L1=true
AGGKIT_WAIT_FOR_L2=true

# =============================================================================
# OPTIONAL: CUSTOM CONFIGURATION
# =============================================================================

# Path to custom configuration file (if using mounted config)
# AGGKIT_CONFIG_PATH=/app/config/custom.toml

# =============================================================================
# DOCKER-SPECIFIC SETTINGS
# =============================================================================

# Image tag for AggKit sandbox
AGGKIT_IMAGE_TAG=latest

# Anvil image tag
ANVIL_IMAGE_TAG=latest

# Port mappings for external access
HOST_L1_PORT=8545
HOST_L2_PORT=8546
HOST_BRIDGE_API_PORT=5577
HOST_RPC_PORT=8555
HOST_METRICS_PORT=8080 